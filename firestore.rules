rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: /quantities/{tabId}
    // Document ID: tabId (e.g., 'dry-stock', 'packaging', 'fresh-produce', 'cafe')
    // Fields:
    //   - quantities: map (required) - A map of item IDs to their quantity values.
    //   - updatedAt: timestamp (required) - The timestamp when the quantities were last updated.
    //   - updatedBy: string (required) - The UID of the user who last updated the quantities.
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          (request.auth.token.email == "nboonyawat3@gmail.com" && request.auth.token.email_verified == true));
    }

    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }

    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    function isValidQuantities(data) {
      return data.quantities is map &&
             data.updatedAt is timestamp &&
             data.updatedBy is string &&
             data.updatedBy == request.auth.uid;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    // Quantities collection
    match /quantities/{tabId} {
      // Allow any authenticated user to read quantities
      allow read: if isAuthenticated();
      
      // Allow any authenticated user to create or update quantities if they follow the schema
      allow create: if isAuthenticated() && 
                      hasRequiredFields(['quantities', 'updatedAt', 'updatedBy']) &&
                      hasOnlyAllowedFields(['quantities', 'updatedAt', 'updatedBy']) &&
                      isValidQuantities(request.resource.data);
                      
      allow update: if isAuthenticated() && 
                      hasRequiredFields(['quantities', 'updatedAt', 'updatedBy']) &&
                      hasOnlyAllowedFields(['quantities', 'updatedAt', 'updatedBy']) &&
                      isValidQuantities(request.resource.data);
                      
      // Only admins can delete quantity documents
      allow delete: if isAdmin();
    }

    // Users collection (for roles)
    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      
      // Only admins can manage roles
      allow write: if isAdmin();
    }
  }
}
